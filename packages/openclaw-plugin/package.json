{
  "name": "@tps/memory-flair",
  "version": "0.1.0",
  "description": "OpenClaw memory plugin backed by Flair (Harper v5) — replaces MEMORY.md with Ed25519-authenticated semantic vector search",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest --testPathPattern=packages/openclaw-plugin"
  },
  "keywords": [
    "openclaw-plugin",
    "memory",
    "flair",
    "tps",
    "harper",
    "ed25519"
  ],
  "license": "MIT",
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
