{
  "name": "@tpsdev-ai/flair",
  "version": "0.5.4",
  "description": "Identity, memory, and soul for AI agents. Cryptographic identity (Ed25519), semantic memory with local embeddings, and persistent personality — all in a single process.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tpsdev-ai/flair.git"
  },
  "homepage": "https://github.com/tpsdev-ai/flair",
  "bugs": {
    "url": "https://github.com/tpsdev-ai/flair/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "identity",
    "memory",
    "semantic-search",
    "embeddings",
    "ed25519",
    "harper",
    "llm",
    "openclaw"
  ],
  "bin": {
    "flair": "dist/cli.js"
  },
  "files": [
    "dist/",
    "schemas/",
    "config.yaml",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.json --noCheck",
    "build:cli": "tsc -p tsconfig.cli.json --noCheck",
    "prepublishOnly": "npm run build && npm run build:cli",
    "test": "bun test",
    "test:e2e": "playwright test",
    "release": "./scripts/release.sh"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@harperfast/harper": "5.0.0",
    "commander": "14.0.3",
    "harper-fabric-embeddings": "0.2.2",
    "jose": "^6.2.2",
    "tweetnacl": "1.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "24.11.0",
    "bun-types": "1.3.11",
    "typescript": "5.9.3"
  },
  "trustedDependencies": [
    "harper-fabric-embeddings"
  ],
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "optionalDependencies": {
    "@node-llama-cpp/mac-arm64-metal": "3.18.1"
  }
}
