{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "bun-types"],
    "paths": {
      "harperdb": ["./types/harperdb.d.ts"]
    }
  },
  "include": ["resources/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
